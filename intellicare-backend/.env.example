# Copy this file to .env and fill in your real values
# Never commit the actual .env file to GitHub

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/intellicare?retryWrites=true&w=majority

# JWT secret — use a long random string (e.g. run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_super_secret_jwt_key_here

# Port the server runs on (Render sets this automatically)
PORT=5000

# Frontend URL for CORS (your Vercel URL once deployed)
FRONTEND_URL=http://localhost:3000
